# ════════════════════════════════════════════════
# Collaborator 설정 파일 (.env.collaborator)
# ML 훈련 참여만 가능, 최소 권한
# ════════════════════════════════════════════════

# === 데이터베이스 (ANON_KEY = RLS 적용) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# === 워커 인증 (관리자가 발급) ===
WORKER_TOKEN=your_worker_token_uuid

# === 안전장치 ===
DRY_RUN=true
EMERGENCY_STOP=false

# === 워커 실행 ===
# python -m scalp_ml.worker --worker-id "your-id" --tier collaborator
#
# === 권한 요약 ===
# ✅ 허용: ML 훈련 (LightGBM, XGBoost, PyTorch)
# ✅ 허용: 백테스트, 파라미터 탐색
# ✅ 허용: 훈련 결과 DB 제출
# ✅ 허용: 시장 데이터/시그널 데이터 읽기 (훈련용)
# ❌ 금지: 모델 배포, 분석, 평가
# ❌ 금지: 실매매 실행
# ❌ 금지: 전략/피드백 수정
# ❌ 금지: 실행 로그/김치랑 데이터 접근
# ❌ 금지: 워커 관리
#
# === 결과 동기화 ===
# python -m scalp_ml.worker --worker-id "your-id" --sync
#
# === 보안 안내 ===
# - 이 파일의 WORKER_TOKEN은 본인 전용입니다
# - 토큰 유출 시 관리자에게 재발급 요청하세요
# - SERVICE_ROLE_KEY는 절대 공유되지 않습니다
