# ════════════════════════════════════════════════
# Coworker 설정 파일 (.env.coworker)
# 훈련 + 분석 참여, 매매/배포 불가
# ════════════════════════════════════════════════

# === 데이터베이스 (ANON_KEY = RLS 적용) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# === 워커 인증 (관리자가 발급) ===
WORKER_TOKEN=your_worker_token_uuid

# === 데이터 수집 (선택사항, 없으면 DB 데이터만 활용) ===
# TAVILY_API_KEY=tvly-your_tavily_api_key

# === 안전장치 (Coworker는 매매 불가) ===
DRY_RUN=true
EMERGENCY_STOP=false

# === 워커 실행 ===
# python -m scalp_ml.worker --worker-id "your-id" --tier coworker
#
# === 권한 요약 ===
# ✅ 허용: ML 훈련, 백테스트, 파라미터 탐색, 분석, 평가
# ✅ 허용: 훈련 결과 DB 제출, 모델 등록
# ✅ 허용: decisions/portfolio/feedback 읽기
# ✅ 허용: 피드백 작성
# ❌ 금지: 모델 배포 (is_active=true)
# ❌ 금지: 실매매 실행
# ❌ 금지: 전략 파일 수정
# ❌ 금지: 워커 관리 (approve/suspend/remove)
#
# === 결과 동기화 ===
# python -m scalp_ml.worker --worker-id "your-id" --sync
