# === 거래소 ===
UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key

# === 데이터 수집 ===
TAVILY_API_KEY=tvly-your_tavily_api_key

# === 데이터베이스 ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# === 알림 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_USER_ID=your_telegram_user_id

# === 안전장치 ===
DRY_RUN=true
MAX_TRADE_AMOUNT=100000
MAX_DAILY_TRADES=3
MAX_POSITION_RATIO=0.5
MIN_TRADE_INTERVAL_HOURS=4
EMERGENCY_STOP=false

# === 단타 전용 (short_term_trader.py) ===
SHORT_TERM_BUDGET=500000
SHORT_TERM_MAX_TRADE=200000
SHORT_TERM_MAX_DAILY=10
SHORT_TERM_STOP_LOSS=0.8
SHORT_TERM_TAKE_PROFIT=1.5
SHORT_TERM_MAX_HOLD_MIN=30

# === LLM-RL 하이브리드 분산 시스템 ===
GEMINI_API_KEY=your_gemini_api_key

# ZeroMQ 통신 (분산 노드 간)
ZMQ_MAIN_BRAIN_HOST=127.0.0.1
ZMQ_MAIN_BRAIN_PORT=5555
ZMQ_PUB_PORT=5556
ZMQ_HEARTBEAT_INTERVAL=30
ZMQ_REQUEST_TIMEOUT=30000

# RAG 임베딩
RAG_EMBEDDING_MODEL=text-embedding-004
RAG_EMBEDDING_DIM=768
RAG_TOP_K=5
