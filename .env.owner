# ════════════════════════════════════════════════
# Owner 설정 파일 (.env.owner)
# Main Brain — 전체 시스템 제어권 보유
# ════════════════════════════════════════════════

# === 거래소 (Owner 전용) ===
UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key

# === 데이터 수집 ===
TAVILY_API_KEY=tvly-your_tavily_api_key

# === 데이터베이스 (SERVICE_ROLE_KEY = RLS 바이패스) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# === 알림 (Owner 전용) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_USER_ID=your_telegram_user_id

# === 안전장치 ===
DRY_RUN=true
MAX_TRADE_AMOUNT=100000
MAX_DAILY_TRADES=6
MAX_POSITION_RATIO=0.5
MIN_TRADE_INTERVAL_HOURS=4
EMERGENCY_STOP=false

# === 단타 전용 ===
SHORT_TERM_BUDGET=1000000
SHORT_TERM_MAX_TRADE=300000
SHORT_TERM_MAX_DAILY=20
SHORT_TERM_STOP_LOSS=1.2
SHORT_TERM_TAKE_PROFIT=0.5
SHORT_TERM_MAX_HOLD_MIN=15

# === 김치랑 (Owner 전용) ===
KR_DRY_RUN=true
KR_EMERGENCY_STOP=false
KR_RL_ENABLED=true
KR_TELEGRAM_STATUS=false

# === LLM-RL 하이브리드 ===
GEMINI_API_KEY=your_gemini_api_key
ZMQ_MAIN_BRAIN_HOST=127.0.0.1
ZMQ_MAIN_BRAIN_PORT=5555
ZMQ_PUB_PORT=5556
ZMQ_HEARTBEAT_INTERVAL=30
ZMQ_REQUEST_TIMEOUT=30000

# === RL 고급 기능 ===
MORL_ENVELOPE=true
MULTI_AGENT_ENABLED=true
LLM_STATE_ENCODER_ENABLED=true
SELF_TUNING_ENABLED=true

# === RAG 임베딩 ===
RAG_EMBEDDING_MODEL=text-embedding-004
RAG_EMBEDDING_DIM=768
RAG_TOP_K=5

# === 워커 등록 ===
# Owner는 SERVICE_ROLE_KEY 사용 (WORKER_TOKEN 불필요)
# python -m scalp_ml.worker --worker-id "your-id" --tier owner
